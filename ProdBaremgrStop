#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
STATE_DIR="${SCRIPT_DIR}/.baremgr"

usage() {
    echo "Usage: $(basename "$0") [config-file]"
    echo "If config-file is omitted, the last started config is used."
}

if [[ $# -gt 1 ]]; then
    usage
    exit 1
fi

resolve_state_file() {
    local config_input="$1"
    local config_path
    local config_hash

    if [[ "${config_input}" = /* ]]; then
        config_path="${config_input}"
    else
        config_path="${SCRIPT_DIR}/${config_input}"
    fi

    config_hash="$(printf '%s' "${config_path}" | cksum | awk '{print $1}')"
    printf '%s\n' "${STATE_DIR}/run_${config_hash}.state"
}

if [[ ! -d "${STATE_DIR}" ]]; then
    echo "No BareMgr runtime state found in ${STATE_DIR}" >&2
    exit 1
fi

if [[ $# -eq 1 ]]; then
    STATE_FILE="$(resolve_state_file "$1")"
else
    STATE_FILE="${STATE_DIR}/last_started.state"
fi

if [[ ! -f "${STATE_FILE}" ]]; then
    echo "State file not found: ${STATE_FILE}" >&2
    exit 1
fi

# shellcheck disable=SC1090
source "${STATE_FILE}"

if [[ -z "${PID:-}" ]]; then
    echo "Invalid state file: PID missing" >&2
    exit 1
fi

TARGET_PID="${PID}"
TARGET_CONFIG_PATH="${CONFIG_PATH:-}"

if ! kill -0 "${TARGET_PID}" 2>/dev/null; then
    echo "Process ${TARGET_PID} is not running. Cleaning stale state."
    rm -f "${STATE_FILE}"
    if [[ -f "${STATE_DIR}/last_started.state" ]]; then
        # shellcheck disable=SC1090
        source "${STATE_DIR}/last_started.state"
        if [[ "${PID:-}" == "${TARGET_PID}" ]] || [[ "${CONFIG_PATH:-}" == "${TARGET_CONFIG_PATH}" ]]; then
            rm -f "${STATE_DIR}/last_started.state"
        fi
    fi
    exit 0
fi

kill -TERM "${TARGET_PID}"

for _ in $(seq 1 20); do
    if ! kill -0 "${TARGET_PID}" 2>/dev/null; then
        break
    fi
    sleep 1
done

if kill -0 "${TARGET_PID}" 2>/dev/null; then
    echo "Process ${TARGET_PID} did not stop after SIGTERM" >&2
    exit 1
fi

rm -f "${STATE_FILE}"
if [[ -f "${STATE_DIR}/last_started.state" ]]; then
    # shellcheck disable=SC1090
    source "${STATE_DIR}/last_started.state"
    if [[ "${PID:-}" == "${TARGET_PID}" ]] || [[ "${CONFIG_PATH:-}" == "${TARGET_CONFIG_PATH}" ]]; then
        rm -f "${STATE_DIR}/last_started.state"
    fi
fi

echo "BareMgr stopped"
echo "  pid    : ${TARGET_PID}"
echo "  config : ${TARGET_CONFIG_PATH:-unknown}"